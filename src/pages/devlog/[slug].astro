---
import { getCollection, render } from "astro:content";
import DevlogLayout from "@/layouts/Devlog.astro";

export async function getStaticPaths() {
    const devlogs = await getCollection("devlog", ({ data }) => {
        return import.meta.env.PROD ? data.draft !== true : true;
    });
    return devlogs.map((log) => ({
        params: { slug: log.id },
        props: { devlog: log },
    }));
}

const { devlog } = Astro.props;
const { Content } = await render(devlog);
---

<DevlogLayout id={devlog.id} devlog={devlog.data}>
    <Content />
</DevlogLayout>
