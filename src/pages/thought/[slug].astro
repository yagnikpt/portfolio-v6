---
import { getCollection, render } from "astro:content";
import ThoughtLayout from "@/layouts/Thought.astro";

export async function getStaticPaths() {
    const thoughts = await getCollection("thought", ({ data }) => {
        return import.meta.env.PROD ? data?.draft !== true : true;
    });
    return thoughts.map((thought) => ({
        params: { slug: thought.id },
        props: { thought },
    }));
}

const { thought } = Astro.props;
const { Content } = await render(thought);
---

<ThoughtLayout id={thought.id} thought={thought.data}>
    <Content />
</ThoughtLayout>
